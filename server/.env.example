# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB — use local MongoDB or a MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/vidyasathi

# Auth — change this to a long random string in production
JWT_SECRET=your_jwt_secret_here

# Google Gemini API — required for AI Tutor, Career, and Quiz features
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email OTP (Gmail SMTP) — required for OTP verification emails
# For Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=VidyaSaathi <your.email@gmail.com>

# OTP email verification for login, register, and password reset
# false = email + password only (for local testing)
# true  = require 6-digit OTP from email
OTP_ENABLED=false

# Scheduled email notifications (task reminders, streak alerts, weekly digest)
# Uses the same SMTP settings above. Without SMTP, emails are logged to the server terminal.
# NOTIFICATION_TIMEZONE=Asia/Kolkata
# DISABLE_NOTIFICATION_SCHEDULER=true
